# orenoBiomni Celery Worker (code execution)
#
# Build:
#   docker build -t orenoiomni-worker -f docker/Dockerfile.worker .

FROM condaforge/miniforge3:latest AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl build-essential r-base \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Create conda env from Biomni's environment.yml
COPY Biomni/biomni_env/environment.yml /tmp/environment.yml
RUN conda env create -f /tmp/environment.yml -n biomni_e1 \
    && conda clean -afy \
    && rm /tmp/environment.yml

# Install worker dependencies
SHELL ["conda", "run", "-n", "biomni_e1", "/bin/bash", "-c"]
RUN pip install -q \
    "celery[redis]>=5.4" \
    "redis>=5.0" \
    "psycopg2-binary>=2.9" \
    "sqlalchemy>=2.0" \
    "pydantic-settings>=2.7"

# Copy and install Biomni (workers need execution functions)
COPY Biomni /app/Biomni
COPY patches /app/patches
WORKDIR /app/Biomni
RUN git apply /app/patches/biomni-ollama-compat.patch 2>/dev/null || true
RUN pip install -e . -q

# Copy backend (workers import task definitions from backend.app)
COPY backend /app/backend
WORKDIR /app

COPY docker/entrypoint-worker.sh /app/entrypoint-worker.sh
RUN chmod +x /app/entrypoint-worker.sh

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD conda run -n biomni_e1 celery -A backend.app.celery_app inspect ping --timeout 5 || exit 1

ENTRYPOINT ["/app/entrypoint-worker.sh"]
