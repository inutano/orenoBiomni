# orenoBiomni Configuration
# Copy to .env and customize

# Model configuration
BIOMNI_LLM=qwen3.5:35b-a3b-q8_0
BIOMNI_SOURCE=Ollama
BIOMNI_TIMEOUT_SECONDS=600

# Ports (host-side; set to empty to disable host binding)
BIOMNI_PORT=7860
FRONTEND_PORT=3000
API_PORT=8000
OLLAMA_PORT=11434
# In production, disable direct access to Postgres and Redis:
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database credentials — CHANGE THESE before deploying
POSTGRES_USER=biomni
POSTGRES_PASSWORD=changeme

# Redis password — set to enable auth (recommended for production)
# When set, also update REDIS_URL to include the password
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
# Example with password: REDIS_URL=redis://:YOUR_PASSWORD@redis:6379/0

# API keys (only needed for cloud LLM providers)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Custom model endpoint (when BIOMNI_SOURCE=Custom)
# BIOMNI_CUSTOM_BASE_URL=http://localhost:8000/v1
# BIOMNI_CUSTOM_API_KEY=

# Celery concurrency (number of parallel code execution workers)
CELERY_CONCURRENCY=2

# Sandbox execution (disabled by default — code runs directly in worker)
# When enabled, code runs in ephemeral Docker containers for isolation.
# Requires: docker compose build sandbox (to build the sandbox image)
# SANDBOX_ENABLED=false
# SANDBOX_IMAGE_PYTHON=orenoiomni-sandbox:latest
# SANDBOX_IMAGE_R=orenoiomni-sandbox:latest
# SANDBOX_IMAGE_BASH=orenoiomni-sandbox:latest
# SANDBOX_CPUS=2.0          # CPU limit per sandbox container
# SANDBOX_MEMORY=4g         # Memory limit per sandbox container
# SANDBOX_NETWORK_DISABLED=true  # Disable network access in sandbox (security)
# SANDBOX_TMPFS_SIZE=512m   # tmpfs /tmp size inside sandbox

# Authentication (disabled by default — all users are anonymous)
# AUTH_ENABLED=false
# AUTH_SECRET=change-me-in-production
# AUTH_REDIRECT_URL=http://localhost:3000

# OAuth: Google (optional, requires AUTH_ENABLED=true)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth: GitHub (optional, requires AUTH_ENABLED=true)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
